import { defineConfig } from "vite";
import glsl from "vite-plugin-glsl"; // Optional: for .glsl files

export default defineConfig({
    base: "./", // Ensures assets load correctly on static hosting like GitHub Pages
    assetsInclude: ["**/*.glb", "**/*.gltf"], // Explicitly include 3D model formats
    plugins: [
        glsl() // Allows you to import shaders directly as strings
    ],
    server: {
        port: 3000,
        open: true
    }
});
